# Production environment variables for Netlify
# Set these in Netlify Dashboard → Site Settings → Environment Variables

# ── Site URL ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://durofiles.durozen.in

# ── Google Apps Script Form Endpoints ─────────────────────────────────────────
# NEXT_PUBLIC_CONTACT_SCRIPT_URL=<your_contact_script_url>
# NEXT_PUBLIC_FEEDBACK_SCRIPT_URL=<your_feedback_script_url>
